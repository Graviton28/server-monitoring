targets_file="/home/researchtech/server_monitoring_scripts/snitch_targets"

check_host() {
	local name="$1" host="$2" ports="$3"
	IFS=',' read -ra port_list <<< "$ports"
	for port in "${port_list[@]}"; do
		if ! { timeout 1 bash -c "echo > /dev/tcp/$host/$port"; } 2>/dev/null; then
			echo "down: $name ($host)"
			return
		fi
	done
	echo "up: $name ($host)"
}

while IFS='|' read -r host name ports; do
	[ -z "$host" ] && continue
	case "$host" in \#*) continue ;; esac
	check_host "$name" "$host" "$ports"
done < "$targets_file"
