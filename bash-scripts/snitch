check_host() {
	local name="$1" host="$2"; shift 2
	for port in "$@"; do
		{ timeout 1 bash -c "echo > /dev/tcp/$host/$port"; } 2>/dev/null || { echo "down: $name ($host)"; return; }
	done
	echo "up: $name ($host)"
}

