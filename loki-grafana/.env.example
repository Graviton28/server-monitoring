# Loki push endpoint, e.g. https://logs-prod.grafana.net or http://loki.internal:3100
LOKI_URL=

# Basic auth (Grafana Cloud style). Leave both blank if your Loki doesn't require auth.
LOKI_USER=
LOKI_API_KEY=

# Only needed for self-hosted multi-tenant Loki that uses X-Scope-OrgID instead of Basic auth.
# LOKI_ORG_ID=

# Label attached to every pushed stream, e.g. prod, staging, homelab.
ENV_LABEL=prod

# How often each mode runs its check, in milliseconds.
CHECK_INTERVAL_MS=15000

# --- agent mode only ---
# Name of the pm2-managed process to read restart/crash history from, if any.
PM2_APP_NAME=

# --- external mode only ---
# Path to the JSON file describing which hosts/URLs to check. See config/targets.example.json.
TARGETS_FILE=./config/targets.json
# Consecutive failed checks required before a target is marked "down".
FAILURE_THRESHOLD=3
